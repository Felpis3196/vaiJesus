# ============================================================================
# Configurações do Sistema de Auditoria de Condomínios com IA
# ============================================================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para config.env
# 2. Preencha os valores conforme necessário
# 3. NUNCA commite o arquivo config.env (já está no .gitignore)
#
# ============================================================================

# ----------------------------------------------------------------------------
# Configurações Gerais da IA
# ----------------------------------------------------------------------------
AI_AUDIT_LOG_LEVEL=INFO
AI_AUDIT_OUTPUT_DIR=./reports
AI_AUDIT_MAX_FILE_SIZE=50
AI_AUDIT_ENABLE_NLP=true
AI_AUDIT_ENABLE_PREDICTIVE=true

# ----------------------------------------------------------------------------
# Integração OpenAI (Opcional)
# ----------------------------------------------------------------------------
# Para usar análise avançada com OpenAI, configure sua chave API
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua-chave-openai-aqui
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT=30

# ----------------------------------------------------------------------------
# Extração via LLM local (sem token externo)
# ----------------------------------------------------------------------------
# Ativar extração de dados por LLM (transações, saldos, holerites, encargos).
# Com LLM local NÃO é necessário OPENAI_API_KEY.
# Exemplo Ollama: LLM_BASE_URL=http://localhost:11434/v1 e LLM_MODEL=llama3.1
LLM_EXTRACTION_ENABLED=false
LLM_BASE_URL=
LLM_MODEL=llama3.1
LLM_EXTRACTION_MAX_TOKENS=8192
LLM_EXTRACTION_TIMEOUT=120
LLM_EXTRACTION_TEMPERATURE=0
LLM_EXTRACTION_MAX_CHARS_PER_CHUNK=100000
LLM_EXTRACTION_RETRIES=2

# ----------------------------------------------------------------------------
# Configurações de Detecção de Anomalias
# ----------------------------------------------------------------------------
ANOMALY_Z_SCORE_THRESHOLD=3.0
ANOMALY_ISOLATION_FOREST_CONTAMINATION=0.05
ANOMALY_MAX_SALARY_THRESHOLD=5000.0
ANOMALY_MIN_VALUE_THRESHOLD=1.0
ANOMALY_MAX_VALUE_THRESHOLD=50000.0

# ----------------------------------------------------------------------------
# Configurações de Processamento de Dados
# ----------------------------------------------------------------------------
DATA_PROCESSING_ENCODING=utf-8
DATA_PROCESSING_DATE_FORMAT=%Y-%m-%d
DATA_PROCESSING_MAX_FILE_SIZE_MB=100

# ----------------------------------------------------------------------------
# Regra de gasto: alerta quando >5% acima do mês passado e acima da inflação
# ----------------------------------------------------------------------------
# Inflação mensal em % (ex.: 0.5 = 0,5%). Usado para comparar variação de despesas.
INFLATION_MONTHLY_PCT=0.5

# ----------------------------------------------------------------------------
# Configurações de Relatórios
# ----------------------------------------------------------------------------
REPORT_OUTPUT_FORMAT=markdown
REPORT_INCLUDE_CHARTS=true
REPORT_LANGUAGE=pt-BR
REPORT_CURRENCY_SYMBOL=R$
REPORT_DECIMAL_PLACES=2

# ----------------------------------------------------------------------------
# Links FGTS / Holerite (extração a partir de URLs do Excel)
# ----------------------------------------------------------------------------
# Habilitado por padrão (1). Definir 0, false ou off para desativar o fetch
# de holerites a partir de links FGTS/holerite extraídos do demonstrativo.
FETCH_FGTS_LINKS=1

# ----------------------------------------------------------------------------
# Configurações de API (Desenvolvimento)
# ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ----------------------------------------------------------------------------
# Notas Importantes
# ----------------------------------------------------------------------------
# - A API não utiliza autenticação JWT (acesso controlado por IP localhost)
# - Para produção, configure autenticação adequada
# - OPENAI_API_KEY é opcional, mas recomendado para análises avançadas
# - Com LLM local (LLM_BASE_URL definido), não é necessário token de GPT-4 mini nem de qualquer IA externa
# - Todos os valores numéricos devem ser números válidos

